<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest
  ExtensionBundleId="com.cleanplatefx.ftrack"
  ExtensionBundleVersion="1.0.0"
  ExtensionBundleName="ftrack panel"
  Version="11.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <ExtensionList>
    <Extension Id="com.cleanplatefx.ftrack.panel" Version="1.0.0" />
  </ExtensionList>
  <ExecutionEnvironment>
    <HostList>
      <!-- After Effects 2019+ through future versions (incl. 2025 / CEP 12) -->
      <Host Name="AEFT" Version="[16.0,99.9]" />
    </HostList>
    <LocaleList>
      <Locale Code="All" />
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="11.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>
  <DispatchInfoList>
    <Extension Id="com.cleanplatefx.ftrack.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./www/index.html</MainPath>
          <ScriptPath>./jsx/host.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--allow-file-access-from-files</Parameter>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>ftrack panel</Menu>
          <Geometry>
            <Size>
              <Width>420</Width>
              <Height>720</Height>
            </Size>
            <MinSize>
              <Width>320</Width>
              <Height>400</Height>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
